# Multi-stage build for go-ai-scheduler ai-service
FROM golang:1.23-alpine AS builder

WORKDIR /build
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/ai-service ./cmd/ai-service

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /app/ai-service /app/ai-service

EXPOSE 8083
ENTRYPOINT ["/app/ai-service"]
