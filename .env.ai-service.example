# Copy this file to a local file that is not committed:
# cp .env.ai-service.example .env.ai-service
# Then edit .env.ai-service with your real credentials and run:
# source .env.ai-service
#
# Run commands from the repository root:
# /root/workspace/go-ai-scheduler

# Shared persistence config for ai-service.
export REPO_BACKEND=mysql
export MYSQL_DSN='root:root@tcp(127.0.0.1:3306)/go_ai_scheduler?parseTime=true'
export AUTO_MIGRATE=false
export MIGRATION_DIR=migrations
export REDIS_ADDR='127.0.0.1:6379'

# ai-service listen address.
export APP_HTTP_ADDR=:8083

# LLM provider config for ai-service.
# Fill in your actual endpoint/key/model in .env.ai-service.
export LLM_ENDPOINT='https://api.openai.com/v1'
export LLM_API_KEY='sk-your-real-key'
export LLM_MODEL='gpt-4o'

# api -> ai-service proxy target.
# Set this when starting the api service.
export AI_SERVICE_URL='http://127.0.0.1:8083'
